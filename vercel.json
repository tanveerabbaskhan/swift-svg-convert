{
  "rewrites": [
    { 
      "source": "/blog/:slug.html", 
      "destination": "/blog/:slug.html" 
    },
    { 
      "source": "/blog/:slug", 
      "destination": "/index.html" 
    },
    { 
      "source": "/blog", 
      "destination": "/index.html" 
    },
    { 
      "source": "/((?!assets|blog|sitemap\\.xml|robots\\.txt|favicon\\.ico).*)", 
      "destination": "/index.html" 
    }
  ]
}
